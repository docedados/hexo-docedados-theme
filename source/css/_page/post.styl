.post
  font-family: $basic-font-family
  margin-bottom: 4em

  section
    &.post-title
      font-family: $header-font-family
      font-size: 2em
      line-height: 1.3em
      font-weight: 600
      position: relative
      letter-spacing: -0.02em

      a:hover
        text-decoration: none

    &.post-meta, &.post-footer
      font-family $header-font-family
      font-size 0.9em
      font-weight 400
      color $font-secondary-color
      letter-spacing 0.02em
      margin-top 10px

      a
        color $font-secondary-color
        text-decoration: underline

        &:hover
          color $global-link-hover-color
          text-decoration: none

    &.post-footer
      clear: both
      line-height: 2

.post-title, .post-meta, .post-footer
  margin 0 10%

.post-content
  // padding-top 2rem
  font-size 1.3em
  line-height: 1.5em;
  margin 15px 0 10px 0
  text-align justify
  display inline-block
  width 100%

  overflow-wrap: break-word;
  word-wrap: break-word;

  word-break: break-word;
  hyphens: auto;

  h2,
  h3,
  h4,
  h5,
  h6
    font-size 1.1em
    margin-top 1.2em
    margin-bottom 1em
    // padding-top .8em
    // padding-bottom .3em
  h1::before
    content "#"
    margin-right 5px
    color $post-link-color
    top: -2px;
    position: relative;
  h2::before
    content "#"
    margin-right 5px
    color $post-link-color
    top: -2px;
    position: relative;
  h3::before
    content "|"
    margin-right 5px
    color $post-link-color
    top: -2px;
    position: relative;
  h4::before
    content "*"
    margin-right 5px
    color $post-link-color
    top: -2px;
    position: relative;

  a:hover
    color $post-link-hover-color

  a
    // brush used from svgbox project, copied to local so we do not depend
    // of third-party cdns
    // background: url(//s2.svgbox.net/pen-brushes.svg?ic=brush-9&color=$post-link-hover-color-with-marker);
    background url("/images/pen-brushes.svg")
    color $post-link-color-with-marker

  ul
    padding-left 2em

  table
    max-width 100%
    margin 10px auto
    border-spacing 0
    thead
      background $post-table-background-color
    th, td
      padding 5px 15px
      border .5px solid $border-color

  p, blockquote, h2, h3, h4, h5, h6, ul, ol, table, pre, iframe
    margin 10px

  // p with their first child being img
  p:has(> img), figure  
    text-align center
    margin 15px 0

  img
    display block
    max-width 100%
    height auto
    margin: 20px auto
    border-radius: 9px
    transition: transform .5s ease // Transition always present for smooth in/out
    transform: scale(1) // Explicit initial state
    &:hover
      transform: scale(1.05) // Apply hover effect to standalone images

  .hexo-gallery-slider
    margin 10px 1.5em 10px 0
    max-width 45%
    display block
    border-radius 9px
    float left

    img
      margin 0

    // Add overflow control based on gallery type
    &:has(.slider > li:nth-child(2))
      .slider-wrap
        border-radius 9px
        overflow hidden
        img
          border-radius 0


  // Apply hover effect only to standalone images (not in galleries)
  img:not(.hexo-gallery-slider img):hover
    transform: scale(1.05)

  img:hover + figcaption
    background-color: rgba($background-color, 1.0)
    transition: background-color .5s ease;
      
  figcaption
    position: relative;
    top: -25px;
    font-style: italic;
    width 50%
    margin 0 auto
    padding 10px
    border-radius: 9px;
    
    p
      margin 0
    
  blockquote
    // background: url('/images/quotes.gif') no-repeat top left;
    // border: none;
    padding 1em 1.2em 1em 1.2em
    // font-style: italic;
    position: relative;
    font-family: monospace;
    // font-size: small;
    line-height: 140%;
    font-weight: normal;
    text-align: left;    
    
  blockquote:after
    content: '\201D';
    font-size: 9em;
    font-family: $basic-font-family
    color: $global-link-hover-color;
    font-weight: bold;
    opacity: 0.3;
    z-index: -1;
    position: absolute;
    left: -30px;
    top: 65px;
    transform: rotate(-17deg);

    // font-size 1rem
    // display block
    // margin 1em 0
    // padding 1em 1.2em 1em 1.2em
    // position relative
    // color rgba(#34495e, 0.8)
    // background-color $post-blockquote-background-color
    // border-left 2px solid $post-blockquote-border-color
    // box-shadow 1px 1px 2px rgba(0,0,0,0.125)
    p
      margin 0
    footer
      strong
        margin-right 0.5em
    &.pullquote
      background-color transparent
      max-width 45%
      border 0
      &.left
        float left
        text-align left
      &.right
        float right
        text-align right 

  .svg-inline--fa
     font-size 1.7em
     vertical-align bottom

  hr
    margin-top 2em
    margin-bottom 2em

  iframe
    display block
    max-width 100%
    margin 0 auto
    overflow hidden
    
  code, pre
    line-height 1.7em
    padding 7px
    font-size 14px
    font-family Consolas, Monaco, Menlo, Consolas, monospace
  code
    line-height 1.7em
    padding 3px 5px
    border-radius 4px
    color $code-font-color
    background $code-background-color

  iframe
    margin 0 auto !important

  figure.highlight
    margin 1em 0
    overflow-x auto
    position relative
    &::-webkit-scrollbar
      width 6px
      height 6px
    &::-webkit-scrollbar-thumb
      width 6px
      background-color #eee
      border-radius 2px
    figcaption
      padding 0 0.5em
      text-align right
      font-size 13px
      span
        margin 0 0.5em
    table
      position relative
    table, tr, td
      margin 0
      padding 0
      border 0
      width 100%
      border-collapse collapse
    .code
      pre
        margin 0 10px

    // line number
    .gutter
      width 10px
      color #d0d0d0
      pre
        margin 0

  .left
    float left
    margin-right 25px
  .right
    float right
    margin-left 25px
  .textright
    text-align right
  .center
    text-align center
  .rounded
    border-radius 100%

.post-nav 
  font-family: $basic-font-family
  font-size: 1em;
  color $font-secondary-color

  a
    color $font-secondary-color
    &:hover
      color $global-link-hover-color

  &:before,
  &:after 
    content: " "
    display: table
  
  & a.prev,
  & a.next 
    transition-property: transform
    transition-timing-function: ease-out
    transition-duration: 0.3s
  
  & a.prev 
    float: left
  
  & a.prev::before 
    content "<"
    margin-right .5em

  & a.prev:hover 
    transform: translateX(-4px)
  
  & a.next 
    float: right
  
  & a.next::after 
    content ">"
    margin-left .5em
  
  & a.next:hover 
    transform: translateX(4px)

.miniblog-post
  border: solid 1px $font-secondary-color;
  border-radius: 5px;
  padding: 0 20px;

  .miniblog-link
    font-size: 1.2em;
    line-height: 1.5em;
    text-decoration: underline;
    font-weight: bold;
    position: relative;

  .miniblog-link::before
    content: "#";
    color: $post-link-hover-color;
    font-size: 5em;
    display: block;
    position: absolute;
    left: -90px;
    top: 31px;
    opacity: 0.3;

@media screen and (max-width: 768px)
  .post-title, .post-meta, .post-footer
    margin 0 5%

  .post-content .hexo-gallery-slider
    max-width 100%

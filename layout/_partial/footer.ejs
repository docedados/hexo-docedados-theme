<%# video: load plyr only when there are embedded players in the page %>
<script>
  (function () {
    var players = document.querySelectorAll('.js-player');
    if (!players.length) return;

    var link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://cdn.plyr.io/3.8.4/plyr.css';
    document.head.appendChild(link);

    var script = document.createElement('script');
    script.src = 'https://cdn.plyr.io/3.8.4/plyr.js';
    script.onload = function () {
      Array.from(players).map(function (p) {
        return new Plyr(p, {
          disableContextMenu: 0,
          youtube: {
            noCookie: 1,
            modestbranding: 1,
            showinfo: 0,
            controls: 0,
          },
        });
      });
    };
    document.body.appendChild(script);
  })();
</script>
